{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 13000",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@polar-sh/nextjs": "^0.9.3",
    "@polar-sh/sdk": "^0.42.1",
    "@repo/ui": "workspace:*",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.0.0",
    "drizzle-orm": "^0.45.1",
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "scrapingbee": "^1.7.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cheerio": "^1.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@tailwindcss/postcss": "^4.1.17",
    "@vitest/coverage-v8": "^4.0.16",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.8",
    "playwright": "^1.56.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.1.17",
    "typescript": "5.9.3",
    "vitest": "^4.0.16"
  }
